rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Documents: client may read its own and update/delete existing docs
      // (e.g. patching storagePath after upload). Creation is server-only via
      // Admin SDK so aggregates stay consistent.
      match /documents/{documentId} {
        allow read, update, delete:
          if request.auth != null && request.auth.uid == userId;
        allow create: if false;
      }

      // Aggregates are denormalized counters maintained by server only.
      match /aggregates/{document} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }
  }
}
